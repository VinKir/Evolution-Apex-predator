    \u043F\u043E\u0434\u0432\u0438\u0436\u043D\u043E\u0441\u0442\u044C \u0438 \u043C\u0435\u043D\u044C\u0448\u0443\u044E
    \u0438\u043D\u0435\u0440\u0446\u0438\u043E\u043D\u043D\u043E\u0441\u0442\u044C
    \u043F\u0440\u0438 \u0441\u043C\u0435\u043D\u0435 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F.
    \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u043E \u0431\u044B\u0441\u0442\u0440\u0435\u0435
    \u043F\u043E\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u0438 \u043B\u0435\u0433\u0447\u0435 \u043A\u043E\u0440\u0440\u0435\u043A\u0442\u0438\u0440\u0443\u0435\u0442
    \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u044E \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F.
    \u042D\u0442\u043E \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0432\u0430\u0436\u043D\u043E
    \u0432 \u0431\u043B\u0438\u0436\u043D\u0435\u043C \u0431\u043E\u044E, \u0433\u0434\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C \u0440\u0435\u0437\u043A\u043E
    \u0440\u0430\u0437\u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F \u0447\u0430\u0441\u0442\u043E
    \u0440\u0435\u0448\u0430\u0435\u0442 \u0438\u0441\u0445\u043E\u0434 \u0441\u0445\u0432\u0430\u0442\u043A\u0438."
