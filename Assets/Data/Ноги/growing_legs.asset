  unlockLevel: 5
  description: "\u0415\u0441\u043B\u0438 \u043B\u0430\u043F\u043A\u0438 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043E\u0442\u043E\u0440\u0432\u0430\u043D\u044B \u0438\u043B\u0438 \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D\u044B,
    \u0432\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F \u0440\u0435\u0437\u0435\u0440\u0432\u043D\u044B\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C \u043F\u043E\u0441\u0442\u0435\u043F\u0435\u043D\u043D\u043E\u0433\u043E
    \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F \u043D\u043E\u0432\u043E\u0439
    \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438. \u0421\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C
    \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u0435\u0442
    \u0443\u0442\u0440\u0430\u0447\u0435\u043D\u043D\u044B\u0439 \u0441\u0435\u0433\u043C\u0435\u043D\u0442,
    \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u044F \u0435\u043C\u0443 \u0440\u0430\u0431\u043E\u0447\u0443\u044E
    \u0444\u043E\u0440\u043C\u0443 \u0438 \u0444\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C.
    \u042D\u0442\u043E \u043C\u0435\u0434\u043B\u0435\u043D\u043D\u044B\u0439 \u043F\u0440\u043E\u0446\u0435\u0441\u0441,
    \u043D\u043E \u043E\u043D \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u043A\u043E\u043C\u043F\u0435\u043D\u0441\u0438\u0440\u043E\u0432\u0430\u0442\u044C
