  displayName: "\u041E\u0441\u0442\u0440\u044B\u0435 \u043C\u0430\u043D\u0434\u0438\u0431\u0443\u043B\u044B"
  unlockLevel: 5
  description: "\u041A\u0440\u0430\u044F \u0447\u0435\u043B\u044E\u0441\u0442\u043D\u044B\u0445
    \u043F\u043B\u0430\u0441\u0442\u0438\u043D \u0443\u0442\u043E\u043D\u0447\u0430\u044E\u0442\u0441\u044F
    \u0438 \u043F\u0440\u0438\u043E\u0431\u0440\u0435\u0442\u0430\u044E\u0442 \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u043D\u0443\u044E
    \u0440\u0435\u0436\u0443\u0449\u0443\u044E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E,
    \u0437\u0430 \u0441\u0447\u0451\u0442 \u0447\u0435\u0433\u043E \u043F\u0440\u0438
    \u0441\u043C\u044B\u043A\u0430\u043D\u0438\u0438 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0430\u0435\u0442
    \u043A\u043E\u043D\u0446\u0435\u043D\u0442\u0440\u0430\u0446\u0438\u044F \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u043D\u0430 \u043F\u043B\u043E\u0449\u0430\u0434\u0438 \u043A\u043E\u043D\u0442\u0430\u043A\u0442\u0430.
    \u0423\u043A\u0443\u0441 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u0438\u043B\u044C\u043D\u0435\u0435,
    \u0430 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043E\u043F\u0430\u0441\u043D\u0435\u0435
    \u0434\u043B\u044F \u043C\u044F\u0433\u043A\u0438\u0445 \u0442\u043A\u0430\u043D\u0435\u0439
    \u0438 \u0441\u043B\u0430\u0431\u043E \u0437\u0430\u0449\u0438\u0449\u0451\u043D\u043D\u044B\u0445
    \u0443\u0447\u0430\u0441\u0442\u043A\u043E\u0432. \u042D\u0442\u043E \u043F\u043E\u0432\u044B\u0448\u0430\u0435\u0442
    \u043E\u0431\u0449\u0438\u0439 \u0443\u0440\u043E\u043D \u0438 \u0434\u0435\u043B\u0430\u0435\u0442
    \u043A\u0430\u0436\u0434\u043E\u0435 \u043F\u043E\u043F\u0430\u0434\u0430\u043D\u0438\u0435
    \u0431\u043E\u043B\u0435\u0435 \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C."
