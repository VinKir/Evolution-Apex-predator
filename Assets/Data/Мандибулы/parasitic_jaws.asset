  variantId: 002005
  displayName: "\u041F\u0430\u0440\u0430\u0437\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0430\u043D\u0434\u0438\u0431\u0443\u043B\u044B"
  unlockLevel: 5
  description: "\u0412\u043D\u0443\u0442\u0440\u0438 \u0447\u0435\u043B\u044E\u0441\u0442\u043D\u043E\u0433\u043E
    \u0430\u043F\u043F\u0430\u0440\u0430\u0442\u0430 \u0444\u043E\u0440\u043C\u0438\u0440\u0443\u044E\u0442\u0441\u044F
    \u043E\u0441\u043E\u0431\u044B\u0435 \u0430\u0431\u0441\u043E\u0440\u0431\u0438\u0440\u0443\u044E\u0449\u0438\u0435
    \u0442\u043A\u0430\u043D\u0438, \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u044B\u0435
    \u0438\u0437\u0432\u043B\u0435\u043A\u0430\u0442\u044C \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u043E
    \u0432\u0430\u0436\u043D\u044B\u0435 \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0430
    \u0438\u0437 \u043F\u043E\u0432\u0440\u0435\u0436\u0434\u0451\u043D\u043D\u043E\u0439
    \u0434\u043E\u0431\u044B\u0447\u0438. \u0427\u0430\u0441\u0442\u044C \u043D\u0430\u043D\u0435\u0441\u0451\u043D\u043D\u043E\u0433\u043E
    \u0443\u0440\u043E\u043D\u0430 \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u0443\u0435\u0442\u0441\u044F
    \u0432 \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445 \u0442\u043A\u0430\u043D\u0435\u0439
    \u0438 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u0435 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C\u0430.
    \u042D\u0442\u043E \u0434\u0435\u043B\u0430\u0435\u0442 \u0443\u043A\u0443\u0441
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0440\u0443\u0436\u0438\u0435\u043C,
    \u043D\u043E \u0438 \u0441\u043F\u043E\u0441\u043E\u0431\u043E\u043C \u043F\u043E\u0434\u043F\u0438\u0442\u043A\u0438
    \u0432 \u0437\u0430\u0442\u044F\u0436\u043D\u043E\u0439 \u0441\u0445\u0432\u0430\u0442\u043A\u0435."
