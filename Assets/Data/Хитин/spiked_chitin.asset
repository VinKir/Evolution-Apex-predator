  displayName: "\u0428\u0438\u043F\u0430\u0441\u0442\u044B\u0439 \u0445\u0438\u0442\u0438\u043D"
  unlockLevel: 5
  description: "\u041D\u0430 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438
    \u0444\u043E\u0440\u043C\u0438\u0440\u0443\u044E\u0442\u0441\u044F \u043A\u0435\u0440\u0430\u0442\u0438\u043D\u043E-\u0445\u0438\u0442\u0438\u043D\u043E\u0432\u044B\u0435
    \u043E\u0441\u0442\u0435\u043E\u0444\u0438\u0442\u044B \u0441 \u0432\u044B\u0441\u043E\u043A\u043E\u0439
    \u0436\u0451\u0441\u0442\u043A\u043E\u0441\u0442\u044C\u044E \u0438 \u043E\u0441\u0442\u0440\u044B\u043C\u0438
    \u043A\u0440\u0430\u044F\u043C\u0438. \u041F\u0440\u0438 \u043A\u043E\u043D\u0442\u0430\u043A\u0442\u0435
    \u0441 \u0430\u0433\u0440\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0448\u0438\u043F\u044B
    \u043D\u0430\u043D\u043E\u0441\u044F\u0442 \u043F\u043E\u0432\u0440\u0435\u0436\u0434\u0435\u043D\u0438\u044F,
    \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E \u0443\u0432\u0435\u043B\u0438\u0447\u0438\u0432\u0430\u044F
    \u043F\u043B\u043E\u0449\u0430\u0434\u044C \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0438 \u0443\u0441\u0438\u043B\u0438\u0432\u0430\u044F \u0442\u0440\u0430\u0432\u043C\u0438\u0440\u0443\u044E\u0449\u0438\u0439
    \u044D\u0444\u0444\u0435\u043A\u0442. \u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0448\u0438\u043F\u044B \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u044B \u043B\u043E\u043C\u0430\u0442\u044C\u0441\u044F
    \u0441 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u0437\u0430\u0437\u0443\u0431\u0440\u0435\u043D\u043D\u044B\u0445 \u043A\u0440\u0430\u0451\u0432,
    \u0443\u0441\u0443\u0433\u0443\u0431\u043B\u044F\u044F \u0440\u0430\u043D\u044B
    \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A\u0430."
